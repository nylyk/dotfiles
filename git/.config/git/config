[commit]
  gpgsign = true
[init]
  defaultBranch = main
[pull]
  rebase = true

[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  syntax-theme = Catppuccin Mocha
  plus-style = syntax "#1e3a2e"
  minus-style = syntax "#3a1e2e"
  line-numbers-plus-style = "#a6e3a1" "#1e3a2e"
  line-numbers-minus-style = "#f38ba8" "#3a1e2e"
  line-numbers-zero-style = "#6c7086"
  navigate = true
  line-number = true
  side-by-side = true
[merge]
  conflictStyle = zdiff3
