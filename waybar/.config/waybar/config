{
  "layer": "top",
  "position": "top",
  "output": ["DP-1", "eDP-1"],
  "modules-left": [
    "ext/workspaces",
    "custom/music"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "cpu",
    "memory",
    "battery",
    "pulseaudio",
    "group/power"
  ],
  "ext/workspaces": {
    "sort-by-id": true,
    "on-click": "activate",
    "on-click-right": "deactivate"
  },
  "custom/music": {
    "interval": 5,
    "format": "пЂЃ  {}",
    "escape": true,
    "exec": "playerctl metadata --format='{{artist}} - {{title}}'",
    "on-click": "playerctl play-pause",
    "max-length": 40
  },
  "clock": {
    "interval": 5,
    "format": "пЃі  {:%a %d %B    пђє  %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "left",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#f5c2e7'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks": "<span color='#b4befe'><b>{:%W}</b></span>",
        "weekdays": "<span color='#b4befe'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_down",
      "on-scroll-down": "shift_up"
    },
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "cpu": {
    "interval": 5,
    "format": "п’ј {usage}%"
  },
  "memory": {
    "interval": 5,
    "format": "п”ћ {percentage}%"
  },
  "battery": {
    "interval": 5,
    "states": {
      "warning": 25,
      "critical": 10
    },
    "events": {
      "on-discharging-warning": "fyi -u normal 'Low Battery'",
      "on-discharging-critical": "fyi -u critical 'Very Low Battery'",
      "on-charging-100": "fyi -u normal 'Battery Full'",
      "on-discharging": "fyi -u normal 'Power Switch' Discharging",
      "on-charging": "fyi -u normal 'Power Switch' Charging"
    },
    "format": "{icon} {capacity}%",
    "format-icons": {
      "default": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
      "charging": ["у°ўџ", "у°ўњ", "у°‚†", "у°‚‡", "у°‚€", "у°ўќ", "у°‚‰", "у°ўћ", "у°‚Љ", "у°‚‹", "у°‚…"],
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "п‘¦",
    "format-icons": {
      "default": [
        "пЂ¦",
        "пЂ§",
        "пЂЁ "
      ]
    },
    "on-click": "pavucontrol",
    "scroll-step": 2
  },
  "custom/suspend": {
    "format": "у°’І",
    "tooltip": false,
    "on-click": "systemctl suspend"
  },
  "custom/reboot": {
    "format": "у°њ‰",
    "tooltip": false,
    "on-click": "~/./.config/waybar/prompt.sh Reboot 'Do you really want to reboot?' Reboot system-reboot 'systemctl reboot'"
  },
  "custom/power": {
    "format": "пЂ‘",
    "tooltip": false,
    "on-click": "~/./.config/waybar/prompt.sh Shutdown 'Do you really want to shutdown?' Shutdown system-shutdown 'shutdown now'"
  },
  "group/power": {
    "orientation": "horizontal",
    "modules": [
      "custom/power",
      "custom/suspend",
      "custom/reboot"
    ],
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false,
      "children-class": "not-power"
    }
  }
}
