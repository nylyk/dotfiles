{
  "layer": "top",
  "position": "top",
  "output": ["DP-1", "eDP-1"],
  "modules-left": [
    "ext/workspaces",
    "custom/music"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "cpu",
    "memory",
    "battery",
    "pulseaudio",
    "group/power"
  ],
  "ext/workspaces": {
    "sort-by-id": true,
    "on-click": "activate",
    "on-click-right": "deactivate"
  },
  "custom/music": {
    "interval": 5,
    "format": "οÄ¹  {}",
    "escape": true,
    "exec": "playerctl metadata --format='{{artist}} - {{title}}'",
    "on-click": "playerctl play-pause",
    "max-length": 40
  },
  "clock": {
    "interval": 5,
    "format": "ο¹≥  {:%a %d %B    οêΚ  %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "left",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#f5c2e7'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks": "<span color='#b4befe'><b>{:%W}</b></span>",
        "weekdays": "<span color='#b4befe'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_down",
      "on-scroll-down": "shift_up"
    },
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "cpu": {
    "interval": 5,
    "format": "ο£Φ {usage}%"
  },
  "memory": {
    "interval": 5,
    "format": "οîû {percentage}%"
  },
  "battery": {
    "interval": 5,
    "states": {
      "warning": 25,
      "critical": 10
    },
    "events": {
      "on-discharging-warning": "fyi -u normal 'Low Battery'",
      "on-discharging-critical": "fyi -u critical 'Very Low Battery'",
      "on-charging-100": "fyi -u normal 'Battery Full'",
      "on-discharging": "fyi -u normal 'Power Switch' Discharging",
      "on-charging": "fyi -u normal 'Power Switch' Charging"
    },
    "format": "{icon} {capacity}%",
    "format-icons": {
      "default": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
      "charging": ["σΑΔü", "σΑΔ€", "σΑ²Ü", "σΑ²΅", "σΑ²à", "σΑΔù", "σΑ²â", "σΑΔû", "σΑ²ä", "σΑ²΄", "σΑ²Ö"],
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "οëΠ",
    "format-icons": {
      "default": [
        "οÄΠ",
        "οÄß",
        "οÄ® "
      ]
    },
    "on-click": "pavucontrol",
    "scroll-step": 5,
    "smooth-scrolling-threshold": 2,
  },
  "custom/suspend": {
    "format": "σΑ£≤",
    "tooltip": false,
    "on-click": "systemctl suspend"
  },
  "custom/reboot": {
    "format": "σΑëê",
    "tooltip": false,
    "on-click": "~/./.config/waybar/prompt.sh Reboot 'Do you really want to reboot?' Reboot system-reboot 'systemctl reboot'"
  },
  "custom/power": {
    "format": "οÄë",
    "tooltip": false,
    "on-click": "~/./.config/waybar/prompt.sh Shutdown 'Do you really want to shutdown?' Shutdown system-shutdown 'shutdown now'"
  },
  "group/power": {
    "orientation": "horizontal",
    "modules": [
      "custom/power",
      "custom/suspend",
      "custom/reboot"
    ],
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false,
      "children-class": "not-power"
    }
  }
}
